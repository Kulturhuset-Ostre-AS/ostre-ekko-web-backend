# Craft — local secrets
/cms/.env
/cms/.env.*
!/cms/.env.example
/cms/config/license.key

# Local database dumps (e.g. mariadb-dump | gzip)
/cms/*.sql
/cms/*.sql.gz

/cms/vendor/
/node_modules/

# Craft — runtime (keep directory + .gitignore only)
/cms/storage/logs/*
!/cms/storage/logs/.gitignore
/cms/storage/runtime/*
!/cms/storage/runtime/.gitignore
/cms/storage/backups/*
!/cms/storage/backups/.gitignore
/cms/storage/config-deltas/

# Web root — generated / large (sync from legacy host or GCS)
/public_html/cpresources/
/public_html/imager/
/public_html/error_log
/public_html/uploads/*
!/public_html/uploads/.gitignore

# Legacy flat layout (if introduced later)
/.env
/.env.*
!/.env.example
/vendor/
/web/cpresources/
/web/assets/*
!/web/assets/.gitignore
/storage/*
!/storage/.gitignore
!/storage/rebrand/.gitignore

# IDE / OS
.DS_Store
.idea/
*.swp
*.swo

# Terraform
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/terraform.tfvars.example
terraform/crash.log
terraform/crash.*.log
terraform/override.tf
terraform/*_override.tf

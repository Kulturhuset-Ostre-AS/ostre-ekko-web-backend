# Craft CMS (typical layout after `composer create-project craftcms/cms`)
/.env
/.env.*
!/.env.example

/vendor/
/node_modules/

# Runtime / generated
/storage/*
!/storage/.gitignore
!/storage/rebrand/.gitignore

/web/cpresources/
/web/assets/*
!/web/assets/.gitignore

# IDE / OS
.DS_Store
.idea/
*.swp
*.swo

# Terraform
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/terraform.tfvars.example
terraform/crash.log
terraform/crash.*.log
terraform/override.tf
terraform/*_override.tf

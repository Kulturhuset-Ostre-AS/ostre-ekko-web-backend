
{#
 # Single artist page
 # Artist related to an event entry
 #
 # - event
 # - artist
 #}

<section id="{{ artist.title|lower|kebab}}" class="section cf">

	<div class="section__side-header u-stick">
		{% include "partials/assets/artistFeaturedImage" %}
	</div>

	<div class="section__main">

		<div class="artist block ">
			<div class="block__content-wrapper">
				{% include 'partials/artist/header' %}
			</div>

			{# Description #}
			<article class="content content-container artist__content">
				<div>
					{% include 'partials/artist/meta' %}
				</div>

				{% include 'partials/elements/content' with {'complexContent': artist.complexContent, 'content': artist.description } %}
				{% include 'partials/artist/links_meta' with {'meta': artist.relatedLinks} only %}

				{# Back to main event link #}
				<div class="button-wrapper cf">
					<a class="button button--right" href="{{ event.url }}">{{ event.title }}</a>
				</div>
			</article>
		</div>
	</div>

	</section>

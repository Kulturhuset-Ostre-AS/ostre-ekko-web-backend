
{#
 # Artists section single entry template
 #
 #}

{% extends "_layout" %}

{% set class = 'single artist-page' %}
{% set title = entry.title %}

{% set artist = entry %}

{% set performances = craft.entries({
		'section': 'performance',
		'with': ['location']
	})
	.relatedTo({ targetElement: artist })
	.orderBy('date desc')
%}

{% set currentPerformance = craft.ekko.currentPerformance(performances) %}

{% set event = craft.entries.section('events').relatedTo({
		targetElement: performances,
		field: 'performances'
	}).one()
%}

{% if event.type.handle == 'festival' and event.darkMode %}
  {% set class = class ~ ' theme-dark' %}
{% endif %}

{% block content %}
	{% include 'artists/type/' ~ event.type ~ '_artist' %}
	{# {% include 'artists/type/general_artist' %} #}
{% endblock %}

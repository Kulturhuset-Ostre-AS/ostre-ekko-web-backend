{% if artist.artistFeaturedPhoto|length %}
	{% set asset = artist.artistFeaturedPhoto[0] ?? null %}
	{% set sizes = [
		'(max-width: 700px) 100vw',
		'(max-width: 1045px) 650px',
		'50vw'
	] %}

	{% include "partials/assets/image-types/square" with {"sizes": sizes} %}
{% else %}
	{# Show placeholder image #}
	<figure style="padding-bottom:100%; border: 1px solid rgba(0, 0, 0, 0.1);" class="artist__image">
		<img src="{{ craft.imager.base64Pixel(1, 1) }}" data-src="{{ url('assets/img/placeholder-general-l.jpg') }}" class="lazyload">
	</figure>
{% endif %}

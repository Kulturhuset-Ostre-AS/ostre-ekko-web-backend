{% if entry.pagePhoto|length %}
	{% set asset = entry.pagePhoto.one() %}
{% endif %}

{% if asset is not defined and entry.newsPhoto|length %}
	{% set asset = entry.newsPhoto.one() %}
{% endif %}

{% if asset %}
	{% set sizes = [
		'(max-width: 700px) 100vw',
		'(max-width: 1045px) 650px',
		'50vw'
	] %}

	{% include "partials/assets/image-types/natural" with {"sizes": sizes} %}
{% endif %}

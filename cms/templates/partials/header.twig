      </a>

      <nav class="nav nav--main">
        <ul>
          {% for node in nodes %}  
            {# node.active or node.hasActiveChild to show active status #}
            {% set isActiveNode = node.active or node.hasActiveChild %}
            
            {# Check if link to festival #}
            {# @TODO: add caching mechanism to avoid fetching home link on all requests #}
            {% set isFestival = false %}

            {% if node.url == '#festival-placeholder' %}
              {% set home = craft.entries.section('homepage').one() %}
              {% set festivalEntry = home.linkedFestival.one() %}
              {% set isFestival = true and festivalEntry %}
            {% endif %}

            {% if node.url != '#festival-placeholder' or isFestival %}
              <li class="nav-item {{ isActiveNode ? 'active-nav' : '' }}">
                {% if isFestival %}
                  {% if home.festivalLinkEnabled %}
                    <a href="{{ festivalEntry.url }}">{{ festivalEntry.title }}</a>
                  {% else %}
                    <a class="disabled-nav">{{ festivalEntry.title }}</a>
                  {% endif %}
                {% else %}
                  {{ node.link }}
                {% endif %}
                
                {# Children #}
                {% if node.hasDescendants %}
                  <nav class="nav nav__sub">
                    <ul>
                      {% set nodeChildren = node.children.all() %}
                      {% for subnode in nodeChildren %}
                        <li class="nav-item {{ subnode.active ? 'active-nav' : '' }} ">
                          {{ subnode.link }}
                        </li>
                      {% endfor %}
                    </ul>
                  </nav>
                {% endif %}
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </nav>

      {% include 'partials/language-nav' %}

      <button class="burger" value="Toggle menu" type="button">Menu<span class="icon burger-icon"></span></button>
    </div>
  {% endset %}

  {% if craft.app.request.pathInfo != '' %}
    {{ navigation|replace('href="' ~ craft.app.request.absoluteUrl ~ '"', 'href="' ~ craft.app.request.absoluteUrl ~ '" class="active-nav"')|raw }}
  {% else %}
    {{ navigation|raw }}
  {% endif %}
</div>
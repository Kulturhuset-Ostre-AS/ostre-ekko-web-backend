<head>
	<meta charset="utf-8">{# Declare content type for correct css characters http://www.w3.org/International/questions/qa-css-charset.en.php#http #}
	<meta http-equiv="Content-Type" content="text/html;charset=utf-8" >{# Use the .htaccess and remove these lines to avoid edge case issues. More info: h5bp.com/b/378 #}
	<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">

	{# TITLE #}
	{% set generalName = siteName|replace('(nb)', '')|replace('(en)', '') %}
	{% set siteTitle = generalName %}
    {% if title is defined %}
        {% set siteTitle = title ~ ' - ' ~ siteTitle %}
    {% endif %}

	<title>{{siteTitle}}</title>

	{% set image = "" %}

	{% if entry is defined and entry.type == 'artist' %}
		{% set title = title ~ ' - ' ~ entry.title %}

    {% if entry.artistFeaturedPhoto|length %}
      {% set image = entry.artistFeaturedPhoto.one() %}
  		{% set imageUrl = image.getUrl('thumb_l') %}
    {% endif %}

	{% elseif entry is defined and entry.type == 'homepage' %}
		{# {% if entry.festival|length > 0 %}{% set e = entry.festival.one() %}{% endif %} #}
		{# {% if entry.upcomingEvents|length > 0 %}{% set e = entry.upcomingEvents.one() %}{% endif %} #}

		{# {% if e is defined %} #}
			{# {% set image = e.eventFeaturedPhoto.one() %} #}
		{# {% endif %} #}
	{% endif %}

	{# META #}
	{# GOOGLE - Verify: http://www.google.com/webmasters/ - Crawler test: http://robhammond.co/tools/seo-crawler - Check SPEED: http://developers.google.com/speed/pagespeed/insights/ #}
	<meta name="author" content="{{ generalName }}" />
	<meta name="title" content="{{ siteTitle }}" />
	<meta name="description" content="{{ description|default(globalInfo.siteDescription) }}" />


	{# FACEBOOK - simple tutorial: http://davidwalsh.name/facebook-meta-tags - facebook debugging tool here: http://developers.facebook.com/tools/debug #}
	<meta property="og:type" content="website" />
	<meta property="og:site_name" content="{{ generalName }}" />
	<meta property="og:url" content="{{ craft.app.request.absoluteUrl }}" />
	<meta property="og:title" content="{{ siteTitle }}" />
	<meta property="og:description" content="{{ description|default(globalInfo.siteDescription) }}" />
	<meta property="og:locale" content="{{ craft.app.locale.id }}" />


	<meta property="image" content="{{ imageUrl|default("") }}"/>
	<meta property="og:image" content="{{ imageUrl|default("") }}" />

	{# TWITTER - https://htmlhead.dev/#twitter-card #}
	<meta name="twitter:card" content="summary">
	<meta name="twitter:site" content="@Ekkofestival">
	<meta name="twitter:url" content="{{ craft.app.request.absoluteUrl }}">
	<meta name="twitter:title" content="{{ siteTitle }}">
	<meta name="twitter:description" content="{{ description|default(globalInfo.siteDescription) }}">
	<meta name="twitter:image" content="{{ imageUrl|default("") }}">

	{# MOBILE META #}
	<meta name="viewport" content="width=device-width, initial-scale=1.0">{# Mobile viewport optimized: j.mp/bplateviewport + Added https://github.com/scottjehl/iOS-Orientationchange-Fix #}

	{# Sets whether a web application runs in full-screen mode. + DOES THIS STILL WORK IN iOS7+ #}
	<meta name="apple-mobile-web-app-capable" content="yes">
	<meta names="apple-mobile-web-app-status-bar-style" content="black-translucent" />

	{# Favicons #}
	<link rel="apple-touch-icon" sizes="57x57" href="/apple-touch-icon-57x57.png?v=gAAlYz4R77">
	<link rel="apple-touch-icon" sizes="60x60" href="/apple-touch-icon-60x60.png?v=gAAlYz4R77">
	<link rel="apple-touch-icon" sizes="72x72" href="/apple-touch-icon-72x72.png?v=gAAlYz4R77">
	<link rel="apple-touch-icon" sizes="76x76" href="/apple-touch-icon-76x76.png?v=gAAlYz4R77">
	<link rel="apple-touch-icon" sizes="114x114" href="/apple-touch-icon-114x114.png?v=gAAlYz4R77">
	<link rel="apple-touch-icon" sizes="120x120" href="/apple-touch-icon-120x120.png?v=gAAlYz4R77">
	<link rel="apple-touch-icon" sizes="144x144" href="/apple-touch-icon-144x144.png?v=gAAlYz4R77">
	<link rel="apple-touch-icon" sizes="152x152" href="/apple-touch-icon-152x152.png?v=gAAlYz4R77">
	<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180x180.png?v=gAAlYz4R77">
	<link rel="icon" type="image/png" href="/favicon-32x32.png?v=gAAlYz4R77" sizes="32x32">
	<link rel="icon" type="image/png" href="/favicon-194x194.png?v=gAAlYz4R77" sizes="194x194">
	<link rel="icon" type="image/png" href="/favicon-96x96.png?v=gAAlYz4R77" sizes="96x96">
	<link rel="icon" type="image/png" href="/android-chrome-192x192.png?v=gAAlYz4R77" sizes="192x192">
	<link rel="icon" type="image/png" href="/favicon-16x16.png?v=gAAlYz4R77" sizes="16x16">
	<link rel="manifest" href="/manifest.json?v=gAAlYz4R77">
	<link rel="shortcut icon" href="/favicon.ico?v=gAAlYz4R77">
	<meta name="msapplication-TileColor" content="#00aba9">
	<meta name="msapplication-TileImage" content="/mstile-144x144.png?v=gAAlYz4R77">
	<meta name="theme-color" content="#ffffff">

	<script src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/4.4.1/js/swiper.js"></script>

	{% if craft.app.env == 'dev' %}
		{% do view.registerJsFile('/local/plugins.js') %}
		{% do view.registerJsFile('/local/main.js') %}
		{% do view.registerCssFile('/local/style.css') %}
	{% else %}	
		{% do view.registerJsFile(rev('plugins.js')) %}
		{% do view.registerJsFile(rev('main.js')) %}
		{% do view.registerCssFile(rev('style.css')) %}
	{% endif %}
	
	{{ head() }}

	{# MODERNIZR - www.modernizr.com/download/#}
	<script src="/assets/components/modernizr.js"></script>
	{# JavaScript at the bottom, except for Modernizr / Respond. Modernizr enables HTML5 elements + feature detects; Respond is a polyfill for min/max-width CSS3 Media Queries #}
</head>

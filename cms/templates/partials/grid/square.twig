{% set size = size|default(6) %}

{% set step = 100 %}
{% set width = size * step %}
{% set height = size * step %}
{% set stroke = 2 %}

{% set tWidth = width + stroke %}
{% set tHeight = height + stroke %}

<svg width="{{ tWidth }}" height="{{ tHeight }}" viewBox="0 0 {{ tWidth }} {{ tHeight }}" fill="none" xmlns="http://www.w3.org/2000/svg">
  {% for i in range(0, size) %}
    {% set pos = i * step + 1 %}
    <line vector-effect="non-scaling-stroke" y1="{{ pos }}" x2="{{ tWidth }}" y2="{{ pos }}" stroke="#E53E24" stroke-width="2"/>  
    <line vector-effect="non-scaling-stroke" x1="{{ pos }}" y2="{{ tWidth }}" x2="{{ pos}}" stroke="#E53E24" stroke-width="2"/>
  {% endfor %}
</svg>

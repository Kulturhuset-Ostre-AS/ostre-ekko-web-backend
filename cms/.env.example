# Copy to `.env` and fill in values (never commit `.env`).

ENVIRONMENT="dev"

# Unique per environment — generate a new UUID for local dev if you like.
APP_ID="CraftCMS--00000000-0000-4000-8000-000000000000"

# Generate: `php craft setup/security-key` or a long random string.
SECURITY_KEY=""

DB_DRIVER="mysql"
DB_SERVER="127.0.0.1"
DB_PORT="3306"
DB_DATABASE="craft"
DB_USER="craft"
DB_PASSWORD=""
DB_SCHEMA=""
DB_TABLE_PREFIX="craft_"

# Local dev URL (include trailing slash).
SITE_URL="http://localhost:8080/"

# --- Google Cloud Storage (craftcms/google-cloud) for public asset volumes ---
# Aliases in config/general.php map these to @gcs* for filesystem project config.
# On GCE with the app service account attached, you can leave GCS_KEY_FILE_JSON empty
# and rely on Application Default Credentials.
GCP_PROJECT_ID=""
GCS_ASSETS_BUCKET=""
# Minified JSON for a service account key with Storage Admin (or equivalent) on the bucket.
GCS_KEY_FILE_JSON=""
# Public object base URL, no trailing slash, e.g. https://storage.googleapis.com/your-bucket-name
GCS_ASSET_BASE_URL=""
